{
	"info": {
		"_postman_id": "8c3df2e9-ef12-421b-873b-fde5bc632a4e",
		"name": "Async Task Processing Engine API",
		"description": "Postman Collection for interacting with the Asynchronous Task Processing Engine REST APIs.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Submit Task",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"type\": \"DATA_EXPORT\",\n  \"priority\": \"HIGH\",\n  \"payload\": \"{\\\"format\\\": \\\"csv\\\"}\",\n  \"submittedBy\": \"postman-client\",\n  \"maxRetries\": 3,\n  \"idempotencyKey\": \"postman-idemp-{{$randomUUID}}\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/tasks",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"tasks"
					]
				},
				"description": "Submit a new task for asynchronous execution. Returns a task ID. Limits processing concurrency to a maximum of 50 in-flight tasks globally."
			},
			"response": []
		},
		{
			"name": "Poll Task Status",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/tasks/e04df2e9-ef12-421b-873b-fde5bc632a4e",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"tasks",
						"e04df2e9-ef12-421b-873b-fde5bc632a4e"
					]
				},
				"description": "Retrieve full execution status, metadata, timings, and audit transitions trail for a specific task ID."
			},
			"response": []
		},
		{
			"name": "List All Tasks",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/tasks",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"tasks"
					]
				},
				"description": "List all tasks submitted to the engine. Supports filtering by status (e.g., `?status=COMPLETED`)."
			},
			"response": []
		},
		{
			"name": "List Tasks Filtered by Status",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/tasks?status=COMPLETED",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"tasks"
					],
					"query": [
						{
							"key": "status",
							"value": "COMPLETED",
							"description": "Filter tasks by lifecycle status (PENDING, IN_PROGRESS, COMPLETED, FAILED, CANCELLED, TIMED_OUT)"
						}
					]
				},
				"description": "Retrieve tasks filtered by their current execution status."
			},
			"response": []
		},
		{
			"name": "Cancel Pending Task",
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/tasks/e04df2e9-ef12-421b-873b-fde5bc632a4e",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"tasks",
						"e04df2e9-ef12-421b-873b-fde5bc632a4e"
					]
				},
				"description": "Cancel a submitted task. This command is only successful if the task is currently in PENDING state."
			},
			"response": []
		},
		{
			"name": "Retrieve Operational Metrics",
			"request": {
				"method": "GET",
